```gitignore
# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temp
tmp/
temp/

# Environment
.env
.env.*

# Python
__pycache__/
*.pyc

# Node
node_modules/

# IDE
.vscode/
.idea/

# Runtime memory
runtime/
sessions/
cache/

# Secrets
secrets/
credentials/

# Local experiments
sandbox/

# Agent transient state
agent-state/
working-memory/
```
